// pond/agent/sandbox — Sandbox locus
//
// CONTRACTS.md § pond/agent/sandbox/ declares:
//
//   locus Sandbox {
//       params { runtime: String = "python3"; timeout_ms: Int = 30000;
//                memory_limit_mb: Int = 512; }
//       fn run_code(code: String) -> SandboxResult fallible(SandboxError);
//       fn run_file(path: String) -> SandboxResult fallible(SandboxError);
//   }
//
// Implements the contract verbatim. v0.8.1 narrowed the
// two-channel rule (#24 v0.2) so user-declared `fn` member fns
// carry `fallible(E)` directly with the full `or raise` /
// `or <substitute>` / `or handler(err)` / `or discard`
// disposition surface — the pre-v0.8.1 `last_error` + paired
// free-fn workaround retired.
//
// Status: UNBLOCKED. The body drives the underlying
// pond/subprocess surface, which itself routes through the
// upstream `std::process::run` primitive. For `run_code(code)`
// we use `std::io::fs::mktemp` (C9) to land a scratch file
// under `/tmp/`, write the snippet via `std::io::fs::write_file`,
// invoke `run_file`, and clean up via `std::io::fs::unlink`
// on a best-effort basis. `memory_limit_mb` is a documented
// no-op (no rlimit hook on the upstream surface yet);
// `timeout_ms` likewise isn't enforced because
// std::process::run has no wall-clock cutoff — see
// FRICTION.md.

import "../../subprocess" as sub;

// Sandbox — Service locus (pattern 3 in the six-pattern catalog).
//
// Holds the runtime command + resource limits across a series
// of `run_code` / `run_file` calls. One Sandbox instance is
// typically reused for the lifetime of an agent session; per-
// run state lives on the SandboxResult return value, not on
// self.
//
// `runtime` is the interpreter / runtime binary (e.g. "python3",
// "node", "ruby"). It must resolve via the inherited PATH; an
// absolute path is recommended in production.
// `timeout_ms` is RESERVED — no upstream wall-clock cutoff yet,
// so the field is plumbed for forward compat but currently a
// no-op (FRICTION.md).
// `memory_limit_mb` is RESERVED — no rlimit hook on the upstream
// surface yet, so it's a documented no-op at v1.
locus Sandbox {
    params {
        runtime:         String = "python3";
        timeout_ms:      Int    = 30000;
        memory_limit_mb: Int    = 512;
    }

    birth() {
        // No resources to acquire — the runtime binary is
        // resolved lazily on each run via pond/subprocess.
        // Placeholder so the body isn't empty (empty lifecycle
        // bodies parse-fail per spec/styleguide.md § Current
        // language gaps).
        let _ = self.timeout_ms;
    }

    dissolve() {
        // No resources to release — child processes are owned
        // by the per-call sub::spawn invocation which already
        // reaps before returning.
        let _ = self.timeout_ms;
    }

    // run_code — write `code` to a temp file, invoke the runtime
    // on it, capture stdout/stderr.
    fn run_code(code: String) -> SandboxResult fallible(SandboxError) {
        let path = std::io::fs::mktemp("/tmp/hale_sb_", ".script")
            or (self.raise_io(err) or raise);
        std::io::fs::write_file(path, code)
            or (self.raise_io_after_cleanup(err, path) or raise);
        let r = self.run_file(path)
            or (self.raise_after_cleanup(err, path) or raise);
        // Best-effort cleanup of the temp file once run_file returned cleanly.
        std::io::fs::unlink(path) or discard;
        return r;
    }

    // run_file — invoke the runtime on an existing file at
    // `path`, capture stdout/stderr.
    fn run_file(path: String) -> SandboxResult fallible(SandboxError) {
        let out = sub::run_cmd(self.runtime, path)
            or (self.raise_spawn(err) or raise);
        return SandboxResult {
            exit_code: out.status.code,
            stdout:    std::str::from_bytes(out.stdout),
            stderr:    std::str::from_bytes(out.stderr),
        };
    }

    // raise_io — error-check fn for std::io::fs::mktemp; re-fails
    // as SandboxError with kind="io". The String return type is
    // never produced (the body always diverges via `fail`); it
    // matches the success type of mktemp so the typechecker
    // accepts `or (self.raise_io(err) or raise)`.
    fn raise_io(e: IoError) -> String fallible(SandboxError) {
        fail SandboxError {
            kind:   "io",
            detail: e.kind + ": " + e.path,
        };
    }

    // raise_io_after_cleanup — error-check fn for write_file; unlinks
    // the (possibly empty) temp file before re-failing so we don't
    // leak it. The Int return type is never produced.
    fn raise_io_after_cleanup(e: IoError, path: String) -> Int fallible(SandboxError) {
        std::io::fs::unlink(path) or discard;
        fail SandboxError {
            kind:   "io",
            detail: e.kind + ": " + e.path,
        };
    }

    // raise_after_cleanup — error-check fn for the nested run_file
    // call; unlinks the temp file before re-raising the inner
    // SandboxError (so the caller sees the original kind/detail,
    // not an "io" wrapper).
    fn raise_after_cleanup(e: SandboxError, path: String) -> SandboxResult fallible(SandboxError) {
        std::io::fs::unlink(path) or discard;
        fail SandboxError {
            kind:   e.kind,
            detail: e.detail,
        };
    }

    // raise_spawn — error-check fn for sub::run_cmd. Translates a
    // subprocess SpawnError into a SandboxError via map_kind and
    // re-fails. The sub::Output return type is never produced.
    fn raise_spawn(e: sub::SpawnError) -> sub::Output fallible(SandboxError) {
        fail SandboxError {
            kind:   map_kind(e.kind),
            detail: e.detail,
        };
    }
}

// map_kind — translate a subprocess SpawnError kind tag into a
// SandboxError kind tag. Free fn (pattern 6) used by the
// run_file body to keep the inner / outer error vocabularies
// in sync.
//
// duplicate-suspected: every pond lib that wraps another pond
// lib's fallible surface needs the same "translate inner kind
// to outer kind" mapping table. Worth a helper or doc anchor
// once two more wrappers land.
fn map_kind(inner: String) -> String {
    if inner == "timeout" {
        return "timeout";
    }
    if inner == "io" {
        return "io";
    }
    if inner == "unsupported" {
        return "spawn_failed";
    }
    // "spawn_failed", "killed", and anything else collapse to
    // the catch-all bucket.
    return "spawn_failed";
}
