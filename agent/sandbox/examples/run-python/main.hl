// pond/agent/sandbox/examples/run-python — minimal consumer demo.
//
// Demonstrates the shape consumers will use against the
// `pond/agent/sandbox` (alias `sandbox`) surface. Vendored
// normally the import looks like:
//
//     import "vendor/pond/agent/sandbox" as sandbox;
//
// In-tree the example reaches the lib via a relative path.
//
// Status: UNBLOCKED. `Sandbox.run_code` / `run_file` are
// fallible(SandboxError) directly per CONTRACTS.md
// (v0.8.1 #24 v0.2 narrowing). Call sites use the value
// channel — `or self.report(err)` for recoverable substitution,
// or `or raise` to propagate.

import "../.." as sandbox;

locus RunPython {
    params {
        code: String = "print('hello')";
    }

    run() {
        // Construct a Sandbox once; reuse across runs.
        let sb = sandbox::Sandbox {
            runtime:         "python3",
            timeout_ms:      5000,
            memory_limit_mb: 256,
        };

        // Inline-snippet path. The fallible method surfaces
        // failure on the value channel; we recover via the
        // error-check fn `report` so the demo can continue.
        let r = sb.run_code(self.code) or self.report(err);
        if r.exit_code >= 0 {
            println("run-python: exit ", r.exit_code);
            println("run-python: stdout: ", r.stdout);
            if len(r.stderr) > 0 {
                println("run-python: stderr: ", r.stderr);
            }
        }
    }

    // Error-check fn — converts the value-channel SandboxError
    // into a recoverable substitute. The substitute carries
    // exit_code = -1 so the caller can detect "we recovered
    // from an error" without re-inspecting err.
    fn report(e: sandbox::SandboxError) -> sandbox::SandboxResult {
        println("run-python: ", e.kind, ": ", e.detail);
        return sandbox::SandboxResult {
            exit_code: -1,
            stdout:    "",
            stderr:    "",
        };
    }
}

fn main() {
    RunPython { };
}
