// pond/agent/sandbox — fallible free-fn helpers.
//
// Per the two-channel rule (KNOWN_GOTCHAS.md G4) Sandbox's
// `run_code` / `run_file` methods can't declare
// `fallible(SandboxError)`. These free-fn companions wrap the
// method calls and surface the error via the value channel for
// consumers that prefer `or raise` / `or default` / `or
// self.handler(err)` over polling `sb.last_error.kind`.
//
// They take the Sandbox as a first arg (rather than living as
// methods that *return* a locus — G3) and are otherwise
// 1:1 with the locus methods. The methods themselves remain
// the canonical surface; these helpers are pure ergonomics.
//
// Status (2026-05-16): same BLOCKED state as the rest of the
// lib — see ./FRICTION.md. The fallible wrappers below
// currently always `fail` because the underlying methods
// always populate `last_error.kind`.

// run_code_at — value-channel wrapper for Sandbox.run_code.
// On success returns the SandboxResult; on failure raises
// the SandboxError that the underlying method recorded on
// `sb.last_error`.
fn run_code_at(sb: Sandbox, code: String) -> SandboxResult fallible(SandboxError) {
    let r = sb.run_code(code);
    if sb.last_error.kind != "" {
        fail SandboxError {
            kind:   sb.last_error.kind,
            detail: sb.last_error.detail,
        };
    }
    return r;
}

// run_file_at — value-channel wrapper for Sandbox.run_file.
fn run_file_at(sb: Sandbox, path: String) -> SandboxResult fallible(SandboxError) {
    let r = sb.run_file(path);
    if sb.last_error.kind != "" {
        fail SandboxError {
            kind:   sb.last_error.kind,
            detail: sb.last_error.detail,
        };
    }
    return r;
}
